# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ==========================
# Node.js & Package Managers
# ==========================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
package-lock.json
yarn.lock

# ==========================
# Next.js & Build Output
# ==========================
/.next/
/out/
/build
.next

# ==========================
# Testing & Coverage
# ==========================
/coverage
/.jest-cache

# ==========================
# Environment Variables
# ==========================
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# ==========================
# IDE & Editor
# ==========================
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-project
*.sublime-workspace

# ==========================
# Logging & Debug
# ==========================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
npm-verbose.log*

# ==========================
# TypeScript
# ==========================
*.tsbuildinfo
next-env.d.ts
/src/generated/prisma

# ==========================
# Database
# ==========================
*.db
*.sqlite
*.sqlite3
/prisma/*.db

# ==========================
# OS Files
# ==========================
.DS_Store
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes

# ==========================
# Uploads & Generated Files
# ==========================
/public/uploads/*
!public/uploads/.gitkeep

# ==========================
# IDE-specific files
# ==========================
.vscode
.idea
.env.local.backup
